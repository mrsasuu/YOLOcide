# YOLOcide backend — environment variables
# Copy to .env and fill in real values for local development.

# HTTP
PORT=8080

# Postgres
DATABASE_URL=postgres://yolocide:yolocide@localhost:5432/yolocide?sslmode=disable

# Session JWTs issued by this service
# Generate with: openssl rand -base64 64
SESSION_JWT_SECRET=replace-me-with-a-long-random-string
SESSION_JWT_TTL=720h

# Sign in with Apple
# APPLE_CLIENT_ID is the iOS app's bundle identifier (the "aud" claim that
# Apple puts on identity tokens issued for the iOS app).
APPLE_CLIENT_ID=com.mrsasuu.YOLOcide.backend

# Sign in with Google
# GOOGLE_CLIENT_IDS is a comma-separated list of allowed audiences. Include
# the iOS client ID(s) used by the app (and any web client ID if you have one).
GOOGLE_CLIENT_IDS=replace.apps.googleusercontent.com
